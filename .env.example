# Polymarket HFT Arbitrage Bot - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: Your Ethereum Private Key
# =============================================================================
# WARNING: Never commit this to version control!
# The private key should NOT have the 0x prefix
POLYBOT_PRIVATE_KEY=your_private_key_here_without_0x_prefix

# =============================================================================
# OPTIONAL: API Credentials
# =============================================================================
# These are automatically derived from your private key if not provided
# POLYBOT_API_KEY=
# POLYBOT_API_SECRET=
# POLYBOT_API_PASSPHRASE=

# =============================================================================
# Database Configuration
# =============================================================================
POLYBOT_DB_PASSWORD=your_secure_password_here

# =============================================================================
# Redis Configuration
# =============================================================================
# POLYBOT_REDIS_PASSWORD=

# =============================================================================
# Monitoring
# =============================================================================
GRAFANA_PASSWORD=admin

# =============================================================================
# Alerting (Optional)
# =============================================================================
# Slack webhook URL for alerts
# POLYBOT_ALERT_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz
